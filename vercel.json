{
  "buildCommand": "pnpm install && pnpm --filter @workspace/ejf-website run build",
  "outputDirectory": "artifacts/ejf-website/dist/public",
  "installCommand": "pnpm install --frozen-lockfile=false",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
